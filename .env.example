# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Create key: https://console.cloud.google.com/google/maps-apis/credentials
# Enable: Maps JavaScript API, Directions API, Places API
# Restrict to your domain in production!
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ─── SMTP (NodeMailer) ───────────────────────────────────────────────────────
# Examples:
#   Gmail:   SMTP_HOST=smtp.gmail.com   SMTP_PORT=587  (use App Password, not real password)
#   Outlook: SMTP_HOST=smtp-mail.outlook.com  SMTP_PORT=587
#   Mailgun: SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password-here

# ─── QR Attendance Secret ────────────────────────────────────────────────────
# Any long random string; used to sign HMAC-SHA256 QR tokens
QR_SECRET=change-this-to-a-random-32+-char-secret

# ─── App URL (for reset-password email links) ────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
